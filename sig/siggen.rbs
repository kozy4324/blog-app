    #   person.name_previously_changed? # => true
    #   person.name_previous_change     # => [nil, "Bill"]
    #   person.reload!
    #   person.previous_changes         # => {}
    # ```
    #
    # Rollback the changes:
    #
    # ```ruby
    #   person.name = "Uncle Bob"
    #   person.rollback!
    #   person.name          # => "Bill"
    #   person.name_changed? # => false
